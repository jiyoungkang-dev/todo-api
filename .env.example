# DB 접속 정보 예시 (.env 로 복사해서 실제 값 입력)
# 실제 비밀번호는 이 파일에 넣지 말 것 — .env 만 사용하고 .env 는 git에 올리지 않음

# 컨테이너 내부에서는 호스트명이 db(서비스명)
DB_URL=jdbc:mysql://db:3306/tododb
# root 로 접속하는 경우 DB_PASSWORD 와 MYSQL_ROOT_PASSWORD 를 동일하게 맞출 것
DB_USERNAME=root
DB_PASSWORD=change_me

# MySQL 컨테이너 초기화용 (docker-compose 에서 사용)
MYSQL_DATABASE=tododb
MYSQL_ROOT_PASSWORD=change_me
